{
  "name": "astroweb",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "deploy": "turbo deploy",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate",
    "db:push": "bun run --filter=@astroweb/db db:push",
    "db:migrate": "turbo db:migrate",
    "seed": "bun run --filter=@astroweb/db seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "bun@1.3.0"
}