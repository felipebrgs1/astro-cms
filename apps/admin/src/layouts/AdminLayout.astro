---
import "../styles/global.css";
import { Button } from "@astroweb/ui";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Admin</title>
  </head>
  <body class="min-h-screen bg-neutral-50 text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100">
    <div class="flex min-h-screen">
      <aside class="w-56 border-r border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
        <a href="/posts" class="mb-6 block text-lg font-bold">astroweb</a>
        <nav class="space-y-1">
          <a href="/posts" class="block rounded-lg px-3 py-2 text-sm hover:bg-neutral-100 dark:hover:bg-neutral-800">Posts</a>
          <a href="/pages" class="block rounded-lg px-3 py-2 text-sm hover:bg-neutral-100 dark:hover:bg-neutral-800">Páginas</a>
        </nav>
      </aside>
      <main class="flex-1 p-6">
        <header class="mb-6 flex items-center justify-between">
          <h1 class="text-2xl font-bold">{title}</h1>
          <slot name="actions" />
        </header>
        <slot />
      </main>
    </div>
  </body>
</html>
