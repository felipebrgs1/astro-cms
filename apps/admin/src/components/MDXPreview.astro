<div class="space-y-3" id="mdx-preview">
  <button
    type="button"
    id="preview-btn"
    class="inline-flex items-center justify-center rounded-lg border border-neutral-200 px-4 py-2 text-sm font-medium hover:bg-neutral-50 dark:border-neutral-700 dark:hover:bg-neutral-800 transition-colors"
  >
    Preview
  </button>
  <div
    id="preview-output"
    class="hidden rounded-lg border border-neutral-200 bg-white p-6 dark:border-neutral-700 dark:bg-neutral-900"
  >
    <div id="preview-loading" class="text-sm text-neutral-500">Carregando...</div>
    <div
      id="preview-content"
      class="prose prose-neutral max-w-none dark:prose-invert"
    ></div>
  </div>
</div>

<script>
  const btn = document.getElementById("preview-btn")!;
  const output = document.getElementById("preview-output")!;
  const loading = document.getElementById("preview-loading")!;
  const content = document.getElementById("preview-content")!;
  const textarea = document.getElementById("content") as HTMLTextAreaElement;

  let visible = false;

  btn.addEventListener("click", async () => {
    visible = !visible;

    if (visible) {
      output.classList.remove("hidden");
      loading.classList.remove("hidden");
      content.innerHTML = "";
      btn.textContent = "Editor";

      try {
        const res = await fetch("/api/mdx-preview", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ content: textarea.value }),
        });
        const data = await res.json();
        loading.classList.add("hidden");
        content.innerHTML = data.html;
      } catch {
        loading.classList.add("hidden");
        content.innerHTML =
          '<p class="text-red-500 text-sm">Erro ao carregar preview</p>';
      }
    } else {
      output.classList.add("hidden");
      btn.textContent = "Preview";
    }
  });
</script>
