---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Card } from "@astroweb/ui";

const posts = await getCollection("posts");
---

<BaseLayout title="astroweb" description="Um blog">
  <h1 class="mb-8 text-3xl font-bold">Posts</h1>
  {
    posts.length === 0 ? (
      <p class="text-neutral-500">Nenhum post publicado ainda.</p>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => (
          <Card>
            <a href={`/${post.id}`} class="no-underline">
              <h2 class="mb-2 text-xl font-semibold hover:text-neutral-600 transition-colors">
                {post.data.title}
              </h2>
            </a>
            {post.data.excerpt && (
              <p class="text-neutral-500 text-sm leading-relaxed">{post.data.excerpt}</p>
            )}
            <time class="mt-3 block text-xs text-neutral-400">
              {new Date(post.data.createdAt).toLocaleDateString("pt-BR")}
            </time>
          </Card>
        ))}
      </div>
    )
  }
</BaseLayout>
